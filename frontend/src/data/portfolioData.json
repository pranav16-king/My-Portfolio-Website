      "id": "proj_zerocarbonix",
      "title": "Zerocarbonix — Carbon Credit MRV & Trading System",
      "description": "An end-to-end ClimateTech platform that digitizes the complete carbon credit lifecycle using AI and blockchain. The system automates Measurement, Reporting & Verification (MRV), enables secure carbon credit issuance, transparent trading, and permanent retirement while supporting ESG reporting and Scope 1, 2, & 3 emissions tracking. It connects farmers, industries, auditors, regulators, and financial institutions through a unified digital ecosystem, making carbon markets more transparent, efficient, and accessible.",
      "features": [
        "AI-powered MRV & carbon estimation",
        "Blockchain-secured carbon credit ledger",
        "Carbon credit trading & retirement",
        "Scope 1, 2 & 3 emission monitoring",
        "Farmer mobile app with GPS & multilingual support",
        "Auditor & regulator dashboards",
        "ESG reporting & analytics",
        "Secure payment integration"
      ],
      "techStack": [
        "AI/ML",
        "FastAPI",
        "React",
        "PostgreSQL",
        "Blockchain",
        "GIS",
        "IoT",
        "Docker"
      ],
      "images": [
        "/assets/projects/zerocarbonix/zerocarbnix (1).png",
        "/assets/projects/zerocarbonix/zerocarbnix (2).png",
        "/assets/projects/zerocarbonix/zerocarbnix (3).png",
        "/assets/projects/zerocarbonix/zerocarbnix (4).png"
      ]
    },
    {
      "id": "proj_overthinkai",
      "title": "OverthinkAI — A Structured Debate System",
      "description": "A four-agent deliberation engine that acts as a structured debate system rather than a standard chatbot. It orchestrates a debate between a Realist, Visionary, Ethicist, and an Adversarial Auditor based on your resource constraints, core values, and risk tolerance. The system enforces strict architectural constraints—pausing execution at a Human Gate if conflict scores exceed 65/100, forcing manual re-weighting of priorities. It provides structured artifacts like a tradeoff matrix, timeline projections, and low-stakes action experiments.",
      "features": [
        "Multi-agent debate engine (Realist, Visionary, Ethicist, Auditor)",
        "Live Tavily web search integration for grounded data",
        "Adversarial Auditor with LangGraph interrupt_before gating mechanism",
        "Pydantic-enforced lack of final recommendation to ensure human agency",
        "Five structured artifacts output (Matrix, Timeline, Actions, Questions)",
        "In-memory session checkpointing with SQLite"
      ],
      "techStack": [
        "FastAPI",
        "Gemini",
        "Groq (Llama-3.3-70b)",
        "LangGraph",
        "Next.js",
        "Python",
        "SQLite",
        "Tailwind CSS",
        "Tavily Search API",
        "TypeScript"
      ],
      "images": [
        "/assets/projects/overthinkai/overthinkai.jpg",
        "/assets/projects/overthinkai/overthinkai 1.jpg",
        "/assets/projects/overthinkai/overthinkai 2.jpg",
        "/assets/projects/overthinkai/overthinkai 3.jpg"
      ]
    },
    {
      "id": "proj_training",
      "title": "Training Intelligence Platform",
      "description": "An enterprise-grade Training Intelligence Platform designed to streamline corporate and institutional learning. It provides role-based dashboards, training management, live quizzes, attendance tracking, performance analytics, certificate automation, and comprehensive reporting through a modern, mobile-first interface.",
      "features": [
        "Role-based Admin & User dashboards",
        "Training session and trainer management",
        "Advanced live quiz system with OTP verification",
        "Real-time quiz monitoring, ranking, and analytics",
        "Attendance and performance tracking",
        "Certificate generation, verification, and PDF download",
        "Learning materials management",
        "Reports, audit logs, and analytics dashboard",
        "Email notifications and campaign management",
        "Mobile-first responsive design with secure authentication"
      ],
      "techStack": [
